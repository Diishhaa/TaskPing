# Telegram API Configurations
# Create a bot using Telegram @BotFather and get the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your Chat ID or Channel ID (e.g. -100xxxxxxxxx or direct user ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# General Configurations (Optional - defaults will apply if omitted)
# Minimum priority score required to send Telegram notifications (0 to 100)
MIN_SCORE_THRESHOLD=40

# Tracker schedule interval (in hours) - used only if running locally as a service
POLLING_INTERVAL_HOURS=3
